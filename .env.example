# Copy this file to .env and fill in your real values.
# DO NOT commit the real .env file to git.

# Required — Jira Cloud
JIRA_EMAIL=your.name@coreweave.com
JIRA_API_TOKEN=paste_your_jira_token_here

# Optional — NetBox (enriches device/rack/interface data)
NETBOX_API_URL=https://coreweave.cloud.netboxapp.com/api
NETBOX_API_TOKEN=paste_your_netbox_token_here

# Optional — OpenAI (AI assistant for ticket summaries, troubleshooting, ticket finder)
# pip install openai  (required for AI features)
OPENAI_API_KEY=paste_your_openai_api_key_here
