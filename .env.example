# Copy this file to .env and fill in your real values.
# DO NOT commit the real .env file to git.
# After creating .env, run: chmod 600 .env

# Required — Jira Cloud
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your.name@example.com
JIRA_API_TOKEN=paste_your_jira_token_here

# Optional — NetBox (enriches device/rack/interface data)
NETBOX_API_URL=https://netbox.example.com/api
NETBOX_API_TOKEN=paste_your_netbox_token_here

# Optional — AI assistant (ticket summaries, troubleshooting, ticket finder)
# pip install openai  (required for AI features — works with any OpenAI-compatible API)
OPENAI_API_KEY=paste_your_openai_api_key_here
#
# --- Free alternatives (pick one) ---
#
# Ollama (local, free): brew install ollama && ollama serve && ollama pull llama3
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# AI_MODEL=llama3
#
# Groq (free cloud): get key at https://console.groq.com
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_your_groq_key_here
# AI_MODEL=llama-3.3-70b-versatile

# Optional — ntfy.sh push notifications (alerts to your phone)
# 1. Install ntfy app on your phone
# 2. Subscribe to your chosen topic name in the app
# 3. Set that topic name here
# Leave empty to disable. Toggle at runtime with "ntfy off" / "ntfy on"
NTFY_TOPIC=cwhelper-yourname

# Site configuration (customize for your deployment)
GRAFANA_BASE_URL=https://grafana.int.example.com
GRAFANA_NODE_UID=your-node-dashboard-uid
GRAFANA_IB_UID=your-ib-dashboard-uid
TELEPORT_PROXY=teleport.na.int.example.com
TELEPORT_DOMAIN=int.example.com
FLEET_LABEL_PREFIX=fleet.example.com
SNIPEIT_BASE_URL=https://snipe.example.com
SUPPORTED_SITES=SITE01,SITE-01
DEFAULT_SITE=US-SITE-01A
KNOWN_SITES=US-SITE-01A,US-SITE-02A,US-SITE-03
